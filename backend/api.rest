@host = http://localhost:3000
@baseUrl = {{host}}/api
# Cambia @usuarioId por el ID del usuario que usa el bloque "Login".
@usuarioId = 1
@tareaId = 1
@asignadoId = 2
@usuarioDesactivarId = 999999

### Health / raiz
GET {{host}}/

### Registrar usuario
# @name registro
POST {{baseUrl}}/auth/registro
Content-Type: application/json

{
  "nombre": "Usuario Demo",
  "email": "demo@gestor.cl",
  "password": "123456",
  "rol": "usuario"
}

### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "demo@gestor.cl",
  "password": "123456"
}

### Registrar administrador
# @name registroAdmin
POST {{baseUrl}}/auth/registro
Content-Type: application/json

{
  "nombre": "Admin Demo",
  "email": "admin.demo@gestor.cl",
  "password": "123456",
  "rol": "administrador"
}

### Login administrador
# @name loginAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin.demo@gestor.cl",
  "password": "123456"
}

### Perfil administrador
GET {{baseUrl}}/auth/perfil
Authorization: Bearer {{loginAdmin.response.body.datos.token}}

### Perfil autenticado
GET {{baseUrl}}/auth/perfil
Authorization: Bearer {{login.response.body.datos.token}}

### Listar tareas publicas
GET {{baseUrl}}/tareas?page=1&limit=10

### Listar tareas por filtros
GET {{baseUrl}}/tareas?estado=revision&prioridad=media&page=1&limit=10

### Obtener tarea por ID
GET {{baseUrl}}/tareas/{{tareaId}}

### Mis tareas
GET {{baseUrl}}/tareas/usuario/mis-tareas
Authorization: Bearer {{login.response.body.datos.token}}

### ERROR 403 - Usuario intentando crear tarea
POST {{baseUrl}}/tareas
Authorization: Bearer {{login.response.body.datos.token}}
Content-Type: application/json

{
  "titulo": "Intento de crear tarea como usuario",
  "descripcion": "Esto debe fallar porque solo admin crea tareas",
  "prioridad": "media",
  "fecha_vencimiento": "2026-06-30",
  "asignado_id": {{usuarioId}}
}

### ADMIN - Crear tarea asignada
# @name crearTareaAdmin
POST {{baseUrl}}/tareas
Authorization: Bearer {{loginAdmin.response.body.datos.token}}
Content-Type: application/json

{
  "titulo": "Revisar avance del modulo",
  "descripcion": "Tarea creada por admin y asignada a un usuario",
  "prioridad": "media",
  "fecha_vencimiento": "2026-06-30",
  "asignado_id": {{usuarioId}}
}

### Obtener tarea creada por admin
GET {{baseUrl}}/tareas/{{crearTareaAdmin.response.body.datos.tarea.id}}

### ADMIN - Editar contenido y asignacion de tarea
PUT {{baseUrl}}/tareas/{{crearTareaAdmin.response.body.datos.tarea.id}}
Authorization: Bearer {{loginAdmin.response.body.datos.token}}
Content-Type: application/json

{
  "titulo": "Revisar avance del modulo actualizado",
  "descripcion": "Contenido editado por admin",
  "prioridad": "alta",
  "fecha_vencimiento": "2026-07-05",
  "asignado_id": {{usuarioId}}
}

### USUARIO - Cambiar estado a revision y agregar notas
PUT {{baseUrl}}/tareas/{{crearTareaAdmin.response.body.datos.tarea.id}}
Authorization: Bearer {{login.response.body.datos.token}}
Content-Type: application/json

{
  "estado": "revision",
  "notas": "Surgio un imprevisto y se deja la tarea en revision."
}

### ERROR 403 - Admin intentando mover estado o notas
PUT {{baseUrl}}/tareas/{{crearTareaAdmin.response.body.datos.tarea.id}}
Authorization: Bearer {{loginAdmin.response.body.datos.token}}
Content-Type: application/json

{
  "estado": "completada",
  "notas": "Esto debe fallar porque el estado y las notas son del usuario asignado."
}

### ERROR 403 - Usuario intentando editar contenido
PUT {{baseUrl}}/tareas/{{crearTareaAdmin.response.body.datos.tarea.id}}
Authorization: Bearer {{login.response.body.datos.token}}
Content-Type: application/json

{
  "titulo": "Cambio no permitido por usuario",
  "descripcion": "Esto debe fallar porque solo admin edita contenido."
}

### ADMIN - Eliminar tarea creada
DELETE {{baseUrl}}/tareas/{{crearTareaAdmin.response.body.datos.tarea.id}}
Authorization: Bearer {{loginAdmin.response.body.datos.token}}

### Listar usuarios (requiere token de administrador)
GET {{baseUrl}}/usuarios
Authorization: Bearer {{login.response.body.datos.token}}

### ADMIN - Listar usuarios
GET {{baseUrl}}/usuarios
Authorization: Bearer {{loginAdmin.response.body.datos.token}}

### ADMIN - Obtener usuario por ID
GET {{baseUrl}}/usuarios/{{usuarioId}}
Authorization: Bearer {{loginAdmin.response.body.datos.token}}

### Obtener usuario por ID
GET {{baseUrl}}/usuarios/{{usuarioId}}
Authorization: Bearer {{login.response.body.datos.token}}

### Actualizar usuario
PUT {{baseUrl}}/usuarios/{{usuarioId}}
Authorization: Bearer {{login.response.body.datos.token}}
Content-Type: application/json

{
  "nombre": "Usuario Demo Actualizado",
  "email": "demo@gestor.cl"
}

### Desactivar usuario (requiere token de administrador)
DELETE {{baseUrl}}/usuarios/{{usuarioDesactivarId}}
Authorization: Bearer {{login.response.body.datos.token}}

### ADMIN - Desactivar usuario por ID
# Cambia @usuarioDesactivarId por un usuario real solo si quieres desactivarlo.
DELETE {{baseUrl}}/usuarios/{{usuarioDesactivarId}}
Authorization: Bearer {{loginAdmin.response.body.datos.token}}

### ERROR 400 - Registro con datos invalidos
POST {{baseUrl}}/auth/registro
Content-Type: application/json

{
  "nombre": "A",
  "email": "correo-invalido",
  "password": "123"
}

### ERROR 400 - Crear tarea con titulo muy corto
POST {{baseUrl}}/tareas
Authorization: Bearer {{login.response.body.datos.token}}
Content-Type: application/json

{
  "titulo": "No",
  "estado": "pendiente",
  "prioridad": "media"
}

### ERROR 401 - Perfil sin token
GET {{baseUrl}}/auth/perfil

### ERROR 401 - Perfil con token invalido
GET {{baseUrl}}/auth/perfil
Authorization: Bearer token-invalido

### ERROR 403 - Listar usuarios sin rol administrador
GET {{baseUrl}}/usuarios
Authorization: Bearer {{login.response.body.datos.token}}

### ERROR 404 - Ruta inexistente
GET {{baseUrl}}/ruta-que-no-existe

### ERROR 404 - Tarea inexistente
GET {{baseUrl}}/tareas/999999

### ERROR 409 - Registro con email ya registrado
POST {{baseUrl}}/auth/registro
Content-Type: application/json

{
  "nombre": "Usuario Repetido",
  "email": "demo@gestor.cl",
  "password": "123456",
  "rol": "usuario"
}
